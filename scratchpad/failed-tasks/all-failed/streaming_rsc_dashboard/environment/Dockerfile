FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep \
        ffmpeg libxcb-shm0 libx11-xcb1 libx11-6 libxcb1 libxext6 libxrandr2 libxcomposite1 libxcursor1 libxdamage1 libxfixes3 libxi6 libgtk-3-0t64 libpangocairo-1.0-0 libpango-1.0-0 libatk1.0-0t64 libcairo-gobject2 libcairo2 libgdk-pixbuf-2.0-0 libxrender1 libasound2t64 libfreetype6 libfontconfig1 libdbus-1-3 libnss3 libnspr4 libatk-bridge2.0-0t64 libdrm2 libxkbcommon0 libatspi2.0-0t64 libcups2t64 libxshmfence1 libgbm1 \
        chromium-browser || true && \
    apt-get install -y --no-install-recommends chromium || true && \
    ln -sf /usr/bin/python3 /usr/bin/python && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm i -g agent-browser && \
    agent-browser install && \
    pip3 install --break-system-packages \
        pytest-json-ctrf \
        pochi-verifier \
        pytest-xprocess \
        requests && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user

# Scaffold the RedwoodSDK starter project at /home/user/myproject and pre-install
# all npm dependencies so the task starts from a ready-to-run environment.
RUN cd /home/user && \
    npx --yes create-rwsdk@latest myproject -f && \
    cd /home/user/myproject && \
    npm install --no-audit --no-fund

LABEL Author="generate-harbor-tasks"
LABEL Description="RedwoodSDK (rwsdk) task environment with a pre-scaffolded starter project at /home/user/myproject, Node.js v24, and browser verification dependencies installed."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep
#   - always required pip3 packages: pytest-json-ctrf
#   - Node.js v24 for the RedwoodSDK task environment
#   - browser verification dependencies: pochi-verifier, agent-browser, ffmpeg, and X/GTK libs
#   - extra pip3 packages used by the verifier: pytest-xprocess, requests
#   - /home/user/myproject: RedwoodSDK starter project scaffolded via `npx create-rwsdk` with
#     npm dependencies pre-installed (including the `rwsdk` package).

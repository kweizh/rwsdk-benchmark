{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "myproject",
  "main": "src/worker.tsx",
  "compatibility_date": "2025-08-21",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "books_db",
      "database_id": "books_db",
      "migrations_dir": "drizzle"
    }
  ],
  "vars": {}
}

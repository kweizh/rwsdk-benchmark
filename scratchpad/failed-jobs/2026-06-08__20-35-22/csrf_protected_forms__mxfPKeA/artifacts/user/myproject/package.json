{
  "name": "myproject",
  "version": "1.0.0",
  "description": "CSRF-Protected Comments API with RedwoodSDK",
  "main": "index.js",
  "type": "module",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite dev",
    "dev:init": "rw-scripts dev-init",
    "preview": "vite preview",
    "worker:run": "rw-scripts worker-run",
    "clean": "npm run clean:vite",
    "clean:vite": "rm -rf ./node_modules/.vite",
    "release": "rw-scripts ensure-deploy-env && npm run clean && npm run build && wrangler deploy",
    "generate": "rw-scripts ensure-env && wrangler types --include-runtime false",
    "check": "npm run generate && npm run types",
    "types": "tsc"
  },
  "dependencies": {
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-server-dom-webpack": "19.2.0",
    "rwsdk": "1.2.11",
    "cookie": "1.1.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.40.0",
    "@cloudflare/workers-types": "4.20260608.1",
    "@types/node": "~25.6.0",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "typescript": "5.6.3",
    "vite": "6.2.6",
    "wrangler": "4.98.0"
  }
}
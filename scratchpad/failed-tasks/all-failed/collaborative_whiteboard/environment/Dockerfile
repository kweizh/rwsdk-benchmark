FROM ubuntu:24.04

RUN apt-get update -y && \
    DEBIAN_FRONTEND=noninteractive apt-get install -y --no-install-recommends \
        curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep \
        ffmpeg libxcb-shm0 libx11-xcb1 libx11-6 libxcb1 libxext6 libxrandr2 libxcomposite1 \
        libxcursor1 libxdamage1 libxfixes3 libxi6 libgtk-3-0t64 libpangocairo-1.0-0 \
        libpango-1.0-0 libatk1.0-0t64 libcairo-gobject2 libcairo2 libgdk-pixbuf-2.0-0 \
        libxrender1 libasound2t64 libfreetype6 libfontconfig1 libdbus-1-3 libnss3 \
        libnspr4 libatk-bridge2.0-0t64 libdrm2 libxkbcommon0 libatspi2.0-0t64 \
        libcups2t64 libxshmfence1 libgbm1 && \
    ln -s /usr/bin/python3 /usr/bin/python && \
    curl -fsSL https://deb.nodesource.com/setup_24.x | bash - && \
    apt-get install -y --no-install-recommends nodejs && \
    npm i -g agent-browser && \
    agent-browser install && \
    pip3 install --break-system-packages \
        pytest-json-ctrf pochi-verifier requests pytest-xprocess && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

RUN mkdir -p /home/user && chmod 0755 /home/user

# Pre-scaffold a fresh RedwoodSDK project at /home/user/myproject and pre-install
# npm dependencies so the dev server can start quickly during evaluation without
# downloading the world inside the startup-timeout window.
RUN cd /home/user && \
    npx --yes create-rwsdk myproject && \
    cd myproject && \
    npm install

LABEL Author="generate-harbor-tasks"
LABEL Description="RedwoodSDK (rwsdk) realtime whiteboard task environment: Ubuntu 24.04 + Node.js v24 + browser verification deps + pre-scaffolded rwsdk project at /home/user/myproject with node_modules pre-installed."

CMD ["/bin/bash", "-c", "trap : TERM INT; sleep infinity & wait"]

# Container contents:
#   - always required apt packages: curl wget ca-certificates git python3 python3-pip python3-pytest bash ripgrep
#   - always required pip3 packages: pytest-json-ctrf
#   - Node.js v24 for the RedwoodSDK (Vite + miniflare) task environment
#   - browser verification dependencies: pochi-verifier, agent-browser, ffmpeg, X libs
#   - pytest helpers: pytest-xprocess, requests
#   - /home/user/myproject: pre-scaffolded RedwoodSDK starter with node_modules pre-installed
